# Multi-Helper MCP 配置模板
# 复制本文件为 .env 并填写你的配置，或直接在 MCP 客户端的 env 字段里传入这些环境变量

# ============ 必填 ============
# 你的 API key（火山云 / 智谱官方 / OpenRouter / 其他 OpenAI 兼容网关）
ARK_API_KEY=your-api-key-here

# 网关地址（默认火山云 coding plan，其他网关请改）
# 火山云 coding plan: https://ark.cn-beijing.volces.com/api/coding/v3
# 智谱官方:           https://open.bigmodel.cn/api/paas/v4
# OpenRouter:         https://openrouter.ai/api/v1
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ============ 视觉模型（看图用）============
# 必须支持图片输入（多模态模型）
# 火山云 coding plan 推荐: doubao-seed-2.0-lite（快，思考模式可关）
VISION_MODEL_ID=doubao-seed-2.0-lite

# ============ 知识模型（快速版，日常事实查询）============
# 火山云 coding plan 推荐: deepseek-v4-flash（快，2s 内返回）
# 如果你的网关没有快速知识模型，可以和 KNOWLEDGE_MODEL_DEEP_ID 填一样的
KNOWLEDGE_MODEL_ID=deepseek-v4-flash

# ============ 知识模型（深度版，复杂分析）============
# 火山云 coding plan 推荐: deepseek-v4-pro（带 reasoning，深度强）
# 配合 reasoning budget=3000 控制耗时在 16s 左右
KNOWLEDGE_MODEL_DEEP_ID=deepseek-v4-pro

# ============ 可选调优 ============
# 图片压缩：最长边像素数，超过会等比缩放。默认 1024，截图识别足够
MAX_IMAGE_SIDE=1024

# 图片压缩：JPEG 质量（0-100）。默认 85，文字清晰且体积小
JPEG_QUALITY=85

# 视觉模型单次返回最大 token 数。默认 800
MAX_OUTPUT_TOKENS=800

# 截图目录：vision_describe 支持 image_path="latest" 自动取最新截图
# 留空则用系统默认（Windows: ~/Pictures/Screenshots，Mac: ~/Desktop，Linux: ~/Pictures）
SCREENSHOT_DIR=
